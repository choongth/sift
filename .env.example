# AWS credentials (use IAM role in production, env vars for local dev)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=ap-southeast-1

# Bedrock model
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6

# Tavily (web search)
TAVILY_API_KEY=...

# Agent config
MAX_ITERATIONS=10
REPORTS_DIR=./reports

# MCP server URL (overridden in Docker: http://mcp:8000/sse)
MCP_SERVER_URL=http://localhost:8000/sse

# PDF tool limits
PDF_MAX_PAGES=20
PDF_FETCH_TIMEOUT=30

# S3 report storage (optional — reports are saved locally if unset)
S3_BUCKET_NAME=your-bucket-name
S3_PRESIGNED_EXPIRY=3600
